# SRE Incident Response Demo Configuration
# ─────────────────────────────────────────────────────────────────

# ── Inference provider ───────────────────────────────────────────
INFERENCE_PROVIDER=ollama
OLLAMA_MODEL=gemma3:1b

# ── Infrastructure ───────────────────────────────────────────────
POSTGRES_USER=spans
POSTGRES_PASSWORD=spans_dev
POSTGRES_DB=spans

# ── Cost-Aware Model Routing ────────────────────────────────────
# In production, map these to different models/tiers:
#   validation (triage) → cheap & fast
#   analysis (diagnosis) → mid-tier
#   reasoning (remediation) → expensive & accurate
MODEL_STRATEGY=cost-aware
MODEL_TRIAGE=ollama/gemma3:1b
MODEL_DIAGNOSIS=ollama/gemma3:1b
MODEL_REMEDIATION=ollama/gemma3:1b

# ── Governance ───────────────────────────────────────────────────
AUTO_APPROVE_THRESHOLD=0.90
OPA_POLICY_MODE=strict
AGENT_BUDGET_LIMIT_USD=50.00

# ── Collaboration ───────────────────────────────────────────────
COLLABORATION_MODE=delegation
