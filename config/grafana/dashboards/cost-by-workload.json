          "range": true,
          "refId": "A"
        }
      ],
      "title": "Estimated Total Cost (USD)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 18,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(agentic_estimated_cost_usd) by (provider)",
          "legendFormat": "{{provider}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Estimated Cost by Provider",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(agentic_tokens_used_total{type=\"input\"}[5m])) by (provider, model)",
          "legendFormat": "input {{provider}}/{{model}}",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "sum(rate(agentic_tokens_used_total{type=\"output\"}[5m])) by (provider, model)",
          "legendFormat": "output {{provider}}/{{model}}",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Token Throughput by Provider and Model (5m rate)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRES}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "id": 4,
      "options": {
        "footer": {
          "enablePagination": true,
          "show": true
        },
        "showHeader": true
      },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT trace_id AS workload,\n       SUM(COALESCE(cost_usd, 0))::numeric(10,4) AS total_cost_usd,\n       SUM(COALESCE(input_tokens, 0) + COALESCE(output_tokens, 0))::bigint AS total_tokens,\n       MAX(created_at) AS last_event\nFROM spans_trace\nWHERE created_at >= NOW() - INTERVAL '24 hours'\nGROUP BY trace_id\nORDER BY total_cost_usd DESC\nLIMIT 20;",
          "refId": "A"
        }
      ],
      "title": "Top 20 Workloads by Cost (Last 24h)",
      "type": "table"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRES}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "id": 5,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('hour', created_at) AS time,\n       agent_role AS metric,\n       SUM(COALESCE(cost_usd, 0))::double precision AS value\nFROM spans_trace\nWHERE created_at >= NOW() - INTERVAL '48 hours'\nGROUP BY 1, 2\nORDER BY 1, 2;",
          "refId": "A"
        }
      ],
      "title": "Hourly Cost by Agent Role (Last 48h)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "agentic",
    "cost",
    "finops"
  ],
